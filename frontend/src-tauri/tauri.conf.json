{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LoL Draft Assistant",
  "version": "0.1.0",
  "identifier": "com.ourtbx.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LoL Draft Assistant",
        "width": 1460,
        "height": 940,
        "minWidth": 1120,
        "minHeight": 760,
        "resizable": true,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis"
  }
}
