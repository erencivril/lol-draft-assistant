# Application settings
LDA_APP_NAME="LoL Draft Assistant"
LDA_APP_ENV="development"
LDA_DEBUG=true
LDA_HOST="127.0.0.1"
LDA_PORT=8000

# Use a JSON array for list-valued settings.
LDA_CORS_ORIGINS='["http://localhost:5173"]'

# Leave these unset to use the repo-relative defaults shown here.
# LDA_PROJECT_ROOT="."
# LDA_DATA_DIR="backend/data"
# LDA_LOGS_DIR="backend/logs"
# LDA_DATABASE_PATH="backend/data/lol_draft_assistant.db"
# LDA_FRONTEND_DIST="frontend/dist"

# Riot Data Dragon settings
LDA_DDRAGON_VERSIONS_URL="https://ddragon.leagueoflegends.com/api/versions.json"
LDA_DDRAGON_CHAMPIONS_URL="https://ddragon.leagueoflegends.com/cdn/{version}/data/en_US/champion.json"
LDA_DDRAGON_ICON_URL="https://ddragon.leagueoflegends.com/cdn/{version}/img/champion/{name}.png"

# Lolalytics settings
LDA_LOLALYTICS_BASE_URL="https://lolalytics.com/lol"
LDA_DEFAULT_REGION="TR"
LDA_DEFAULT_RANK_TIER="emerald"

# Runtime polling and refresh settings
LDA_POLL_INTERVAL_SECONDS=2.0
LDA_SCRAPE_PAGE_CONCURRENCY=6
LDA_SCRAPE_FALLBACK_CONCURRENCY=1
LDA_SCRAPE_TIMEOUT_SECONDS=45.0
LDA_SCRAPE_DELAY_SECONDS=0.5
LDA_PATCH_PROBE_MINUTES=10
LDA_REFRESH_LOOP_MINUTES=10
LDA_REFRESH_BATCH_LIMIT=18
LDA_TIER_REFRESH_INTERVAL_HOURS=1
LDA_HOT_BUILD_REFRESH_INTERVAL_HOURS=2
LDA_COLD_BUILD_REFRESH_INTERVAL_HOURS=6
LDA_AGGREGATE_BUILD_REFRESH_INTERVAL_HOURS=12
LDA_SCHEDULED_REGIONS='["BR","EUNE","EUW","JP","KR","NA","OCE","RU","TR"]'
LDA_SCHEDULED_RANKS='["iron","bronze","silver","gold","platinum","emerald","diamond","master","grandmaster","challenger","all","gold_plus","platinum_plus","emerald_plus","diamond_plus","grandmaster_plus"]'
LDA_SCHEDULED_ROLES='["top","jungle","middle","bottom","support"]'
LDA_SCHEDULED_RESUME=true
LDA_HOT_REGIONS='["TR","EUW","NA","KR"]'
LDA_HOT_RANKS='["silver","gold","platinum","emerald","diamond","all","gold_plus","emerald_plus","diamond_plus"]'
LDA_AGGREGATE_RANKS='["all","gold_plus","platinum_plus","emerald_plus","diamond_plus","grandmaster_plus"]'
LDA_ENABLE_LOCAL_LCU=true
LDA_ENABLE_REFRESH_SCHEDULER=true
LDA_ENABLE_BRIDGE_HOUSEKEEPING=true
LDA_BRIDGE_TOKENS="replace-with-a-long-random-token"
LDA_BRIDGE_SESSION_TIMEOUT_SECONDS=30
LDA_ADMIN_ENABLED=true

# Leave unset to use platform-specific lockfile discovery.
# LDA_LCU_LOCKFILE_PATH="C:/Riot Games/League of Legends/lockfile"
